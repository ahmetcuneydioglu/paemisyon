// Paemisyon — Prisma şeması
// Kaynak: docs/06-database-design.md
// İlke: içerik sürümlenir (silinmez), iş verisi ilişkiseldir, modül-agnostik çekirdek.
// Not: UUID için Postgres gen_random_uuid() (v4). İleride UUIDv7 uzantısına geçilebilir.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Supabase pooler (uygulama sorguları)
  directUrl = env("DIRECT_URL") // doğrudan bağlantı (migration için)
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserStatus {
  active
  suspended
  deleted
}

enum AuthProvider {
  email
  apple
  google
}

enum ContentStatus {
  draft
  in_review
  published
  archived
}

enum Difficulty {
  easy
  medium
  hard
}

enum PlanPeriod {
  none
  monthly
  quarterly // 3 aylık — web'in tek satılabilir planı (manuel ödeme)
  yearly
}

enum SubscriptionStatus {
  active
  expired
  grace
  cancelled
  refunded
}

enum PaymentProvider {
  apple
  google
  manual
}

enum LegacySource {
  ios_firebase
  web_mysql
}

enum QuizMode {
  practice
  exam
  daily
  review
  deneme // randevulu canlı deneme (Doc 18)
}

enum QuizSessionStatus {
  in_progress
  completed
  abandoned
}

// ─────────────────────────────────────────────
// Identity & Access
// ─────────────────────────────────────────────

model User {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String     @unique
  emailVerifiedAt       DateTime?  @map("email_verified_at")
  displayName           String     @map("display_name")
  avatarUrl             String?    @map("avatar_url")
  status                UserStatus @default(active)
  onboardingCompletedAt DateTime?  @map("onboarding_completed_at")
  // Hedef sınav (onboarding'de seçilir; Home/katalog varsayılanı — Doc 11 §2).
  preferredModuleId     String?    @map("preferred_module_id") @db.Uuid
  // Günlük soru hedefi (koç hero halkası — Doc 19 §3.2). Kullanıcı ayarlayabilir.
  dailyGoal             Int        @default(20) @map("daily_goal")
  // Hedef sınav tarihi (Doc 25 §3 durum makinesi: exam_mode/taper). Kullanıcı ayarlar.
  targetExamDate        DateTime?  @map("target_exam_date") @db.Date
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  deletedAt             DateTime?  @map("deleted_at")

  authIdentities   AuthIdentity[]
  roles            UserRole[]
  entitlement      Entitlement?
  subscriptions    Subscription[]
  dailyUsage       DailyUsage[]
  quizSessions     QuizSession[]
  topicProgress    UserTopicProgress[]
  stats            UserStats?
  streak           Streak?
  bookmarks        Bookmark[]
  wrongAnswers     WrongAnswer[]
  questionReports  QuestionReport[]
  badges           UserBadge[]
  masterySnapshots TopicMasterySnapshot[]
  preferredModule  ExamType?              @relation(fields: [preferredModuleId], references: [id])

  @@map("users")
}

model AuthIdentity {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  provider    AuthProvider
  providerUid String       @map("provider_uid")
  createdAt   DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
  @@map("auth_identities")
}

model Role {
  id    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key   String     @unique // admin | editor | user
  name  String
  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────
// Content (sürümlü) — Modül → Ders → Konu → Soru
// ─────────────────────────────────────────────

/// Sınav Türü (Doc 21) — PAEM, Misyon, ileride Başkomiserlik…
/// Yeni sınav türü eklemek = SATIR eklemek (şema değişikliği değil).
/// Tablo adı geriye uyum için "modules" kaldı (veri migration'ı gerektirmez).
model ExamType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique // paem, misyon, pomem...
  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections       ExamSection[]
  preferredUsers User[]

  @@map("modules")
}

/// Müfredat bölümü (Doc 21 §2): sınav türünde KULLANICIYA GÖRÜNEN ders başlığı.
/// İçerik dersi (Course) küreseldir; bölüm başlık + ağırlık + sırayı taşır.
/// Örn. Misyon "Anayasa ve İdare Hukuku" (%10) → 2 içerik dersine bağlanır.
model ExamSection {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examTypeId    String    @map("exam_type_id") @db.Uuid
  name          String
  /// Sınavdaki ağırlık (PAEM Genel Kültür %30…) — deneme üretimi bunu kullanır.
  weightPercent Int       @default(0) @map("weight_percent")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  examType ExamType            @relation(fields: [examTypeId], references: [id])
  courses  ExamSectionCourse[]

  @@index([examTypeId])
  @@map("exam_sections")
}

/// Bölüm ↔ içerik dersi bağlantısı (N:N) — veri tekrarı olmadan paylaşım.
model ExamSectionCourse {
  sectionId String @map("section_id") @db.Uuid
  courseId  String @map("course_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")

  section ExamSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course  Course      @relation(fields: [courseId], references: [id])

  @@id([sectionId, courseId])
  @@index([courseId])
  @@map("exam_section_courses")
}

/// Admin/editor işlemlerinin izi (Doc 9 §6) — kim, neyi, ne zaman.
/// Eski sistemdeki "ekip_loglar" fikrinin sağlıklı hali; panel salt-okur gösterir.
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  actorEmail String   @map("actor_email")
  action     String // örn: question.create, question.approve, user.suspend
  entityType String   @map("entity_type") // question | course | topic | user | plan...
  entityId   String?  @map("entity_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

/// İçerik dersi (Doc 21) — KÜRESEL havuz: sınav türüne gömülü değil; müfredat
/// bölümleri (ExamSection) üzerinden bir veya birden çok sınava bağlanır.
model Course {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  sections     ExamSectionCourse[]
  topics       Topic[]
  quizSessions QuizSession[]

  @@map("courses")
}

/// Konu — SELF-REFERENCING AĞAÇ (Doc 21): parentId null = Konu, dolu = Alt
/// Konu. Derinlik esnek; ileri seviye eklemek şema değişikliği gerektirmez.
/// Sorular herhangi bir düğüme (tipik yaprak) bağlanır; mastery/koç/snapshot/
/// matchKeywords topicId bazlı olduğundan hiçbiri etkilenmez.
model Topic {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String    @map("course_id") @db.Uuid
  parentId      String?   @map("parent_id") @db.Uuid
  name          String
  sortOrder     Int       @default(0) @map("sort_order")
  isPremium     Boolean   @default(false) @map("is_premium")
  // Toplu içe aktarmada soruyu bu konuya otomatik eşleyen desenler (Doc 20).
  // Örn. "657 Devlet Memurları Kanunu" → ["657 sayılı", "Devlet Memurları Kanunu"].
  // Taksonomi = eşleme tablosu: admin konuyu düzenleyerek yönetir.
  matchKeywords String[]  @map("match_keywords")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  course           Course                 @relation(fields: [courseId], references: [id])
  parent           Topic?                 @relation("TopicTree", fields: [parentId], references: [id])
  children         Topic[]                @relation("TopicTree")
  questions        Question[]
  quizSessions     QuizSession[]
  userProgress     UserTopicProgress[]
  masterySnapshots TopicMasterySnapshot[]
  lawArticles      LawArticle[]

  @@index([courseId])
  @@index([parentId])
  @@map("topics")
}

/// Resmî madde metni (Doc 25 §4 adım 3 — "kanun metni içerik hattı").
/// Kanun = Topic; madde = Question.articleNo etiketiyle AYNI kanonik biçim
/// ("16", "4/A", "Ek 6", "Geçici 2"). Böylece Madde Atlası'nda soru grubu ile
/// metin tek anahtarda (topicId, articleNo) buluşur.
///
/// İLKE (anayasa): metin AI ile ÜRETİLMEZ/ÖZETLENMEZ — birebir resmî metin;
/// kaynak (mevzuat.gov.tr) ve doğrulama tarihi her zaman görünür. Doğrulanmadan
/// (status=published) istemciye SIZMAZ; import taslak (draft) yazar, admin yayınlar.
model LawArticle {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topicId   String @map("topic_id") @db.Uuid
  articleNo String @map("article_no")
  /// Birebir resmî madde metni (fıkralar korunur; \n ile satırlar).
  text      String

  /// Kaynak künyesi — istemcide görünür (güven vaadi).
  sourceName String  @default("mevzuat.gov.tr") @map("source_name")
  sourceUrl  String? @map("source_url")
  /// Yürürlük/işlenme notu (ör. "5/7/2022 tarihli değişiklik işlenmiş metin").
  effectiveInfo String? @map("effective_info")
  /// İçeriğin resmî kaynağa göre son doğrulandığı an (istemcide "… itibarıyla").
  lastVerifiedAt DateTime? @map("last_verified_at")

  status ContentStatus @default(draft)

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // Kanun başına madde tekil; import upsert bu anahtara dayanır.
  @@unique([topicId, articleNo])
  @@index([topicId, status])
  @@map("law_articles")
}

// Kararlı KİMLİK — içerik burada değil, sürümlerde.
model Question {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topicId          String    @map("topic_id") @db.Uuid
  // Madde Atlası (Doc 25 §4): sorunun bağlı olduğu kanun maddesi ("16", "4/A",
  // "Ek 1", "Geçici 2"). Kanun = topic; madde bu etiketle çözülür. Import'ta
  // otomatik tespit edilir (detectArticleNo), elle düzeltilebilir.
  articleNo        String?   @map("article_no")
  currentVersionId String?   @unique @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  topic          Topic             @relation(fields: [topicId], references: [id])
  reports        QuestionReport[]
  versions       QuestionVersion[] @relation("QuestionVersions")
  currentVersion QuestionVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  examQuestions  ExamQuestion[]

  @@index([topicId])
  @@index([topicId, articleNo])
  @@map("questions")
}

// İçerik burada — DEĞİŞMEZ sürümler.
model QuestionVersion {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId  String        @map("question_id") @db.Uuid
  versionNo   Int           @map("version_no")
  stem        String
  explanation String?
  difficulty  Difficulty    @default(medium)
  mediaUrl    String?       @map("media_url")
  // Soru kaynağı (örn. "30 Kasım 2025 Adalet Bakanlığı GYS — Zabıt Kâtibi").
  // Kullanıcıya gösterimi app_settings.show_question_source ile açılır/kapanır.
  sourceLabel String?       @map("source_label")
  // İçerik parmak izi (Doc 20 EK 2) — tekrar (mükerrer soru) tespiti.
  // sha256(normalize(kök) + sıralı şık metinleri). İçe aktarımda yazılır.
  contentHash String?       @map("content_hash")
  status      ContentStatus @default(draft)
  authoredBy  String?       @map("authored_by") @db.Uuid
  reviewedBy  String?       @map("reviewed_by") @db.Uuid
  publishedAt DateTime?     @map("published_at")
  archivedAt  DateTime?     @map("archived_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  question          Question         @relation("QuestionVersions", fields: [questionId], references: [id])
  currentOfQuestion Question?        @relation("CurrentVersion")
  options           QuestionOption[]
  legalReferences   LegalReference[]
  examQuestions     ExamQuestion[]

  @@unique([questionId, versionNo])
  @@index([questionId, status])
  @@index([contentHash])
  @@map("question_versions")
}

model QuestionOption {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionVersionId String  @map("question_version_id") @db.Uuid
  label             String // A, B, C, D, E
  text              String
  isCorrect         Boolean @default(false) @map("is_correct")
  sortOrder         Int     @default(0) @map("sort_order")

  questionVersion QuestionVersion @relation(fields: [questionVersionId], references: [id], onDelete: Cascade)

  @@index([questionVersionId])
  @@map("question_options")
}

model LegalReference {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionVersionId String    @map("question_version_id") @db.Uuid
  citation          String // örn. "2559 sayılı PVSK md. 4/A"
  url               String?
  effectiveDate     DateTime? @map("effective_date") @db.Date

  questionVersion QuestionVersion @relation(fields: [questionVersionId], references: [id], onDelete: Cascade)

  @@index([questionVersionId])
  @@map("legal_references")
}

// ─────────────────────────────────────────────
// Subscription & Monetization
// ─────────────────────────────────────────────

model Plan {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key                   String     @unique // free | monthly | yearly
  name                  String
  price                 Decimal?   @db.Decimal(10, 2)
  currency              String     @default("TRY")
  period                PlanPeriod @default(none)
  dailyQuestionLimit    Int?       @map("daily_question_limit") // free için sınır; premium null=sınırsız
  storeProductIdIos     String?    @map("store_product_id_ios")
  storeProductIdAndroid String?    @map("store_product_id_android")
  isActive              Boolean    @default(true) @map("is_active")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  planId                String             @map("plan_id") @db.Uuid
  provider              PaymentProvider
  status                SubscriptionStatus
  originalTransactionId String             @map("original_transaction_id")
  currentPeriodEnd      DateTime?          @map("current_period_end")
  autoRenew             Boolean            @default(true) @map("auto_renew")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@map("subscriptions")
}

// Türetilmiş erişim — hızlı kontrol (SubscriptionGuard buradan okur).
model Entitlement {
  userId               String    @id @map("user_id") @db.Uuid
  isPremium            Boolean   @default(false) @map("is_premium")
  validUntil           DateTime? @map("valid_until")
  sourceSubscriptionId String?   @map("source_subscription_id") @db.Uuid
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("entitlements")
}

// Freemium günlük limit — sunucu-taraflı sayaç.
model DailyUsage {
  userId            String   @map("user_id") @db.Uuid
  usageDate         DateTime @map("usage_date") @db.Date
  questionsAnswered Int      @default(0) @map("questions_answered")
  dailyLimit        Int      @map("daily_limit")
  // AI açıklama hakkı (Doc 24 §11: free günde 3, premium sınırsız).
  aiExplanationsUsed Int     @default(0) @map("ai_explanations_used")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, usageDate])
  @@map("daily_usage")
}

// ─────────────────────────────────────────────
// Learning — Quiz oturumları (Doc 6 §4.3)
// ─────────────────────────────────────────────

/// Randevulu canlı deneme (Doc 18) — eski ekip_sinav'ın modern karşılığı.
/// Küresel zaman penceresi: startAt..startAt+durationMinutes (herkese aynı).
model Exam {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String
  description           String?
  startAt               DateTime      @map("start_at")
  durationMinutes       Int           @map("duration_minutes")
  isPremium             Boolean       @default(false) @map("is_premium") // eski kredi yerine (Doc 18 karar 2)
  liveAnswerReveal      Boolean       @default(false) @map("live_answer_reveal") // varsayılan KAPALI (karar 5)
  questionsOpenAfterEnd Boolean       @default(true) @map("questions_open_after_end")
  status                ContentStatus @default(draft)
  sortOrder             Int           @default(0) @map("sort_order")
  createdBy             String?       @map("created_by") @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  questions ExamQuestion[]
  sessions  QuizSession[]

  @@index([status, startAt])
  @@map("exams")
}

/// Denemenin sabit soru seti. questionVersionId YAYIN ANINDA sabitlenir —
/// soru sonradan güncellense bile deneme ve geçmiş sonuçlar bozulmaz (Doc 18 §6).
model ExamQuestion {
  examId            String @map("exam_id") @db.Uuid
  questionId        String @map("question_id") @db.Uuid
  questionVersionId String @map("question_version_id") @db.Uuid
  sortOrder         Int    @map("sort_order")

  exam            Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  question        Question        @relation(fields: [questionId], references: [id])
  questionVersion QuestionVersion @relation(fields: [questionVersionId], references: [id])

  @@id([examId, questionId])
  @@map("exam_questions")
}

model QuizSession {
  id                     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String            @map("user_id") @db.Uuid
  mode                   QuizMode
  topicId                String?           @map("topic_id") @db.Uuid
  // Deneme sınavı kapsamı: ders geneli (konular karışık) — topicId yerine.
  courseId               String?           @map("course_id") @db.Uuid
  // Randevulu deneme (Doc 18): katılım = bu oturum. (userId, examId) tekildir.
  examId                 String?           @map("exam_id") @db.Uuid
  status                 QuizSessionStatus @default(in_progress)
  totalQuestions         Int               @map("total_questions")
  correctCount           Int               @default(0) @map("correct_count")
  wrongCount             Int               @default(0) @map("wrong_count")
  blankCount             Int               @default(0) @map("blank_count")
  score                  Decimal?          @db.Decimal(5, 2)
  durationSeconds        Int?              @map("duration_seconds")
  // Deneme sınavı süresi (sn) — exam modunda dolu; sunucu aşımı reddeder.
  plannedDurationSeconds Int?              @map("planned_duration_seconds")
  // Seçilen soruların sürüm id sırası (JSON dizi) — devam/kaldığı yerden (Doc 27).
  questionOrder          Json?             @map("question_order")
  startedAt              DateTime          @default(now()) @map("started_at")
  completedAt            DateTime?         @map("completed_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic   Topic?       @relation(fields: [topicId], references: [id])
  course  Course?      @relation(fields: [courseId], references: [id])
  exam    Exam?        @relation(fields: [examId], references: [id])
  answers QuizAnswer[]

  // NULL examId'ler Postgres'te tekilliğe takılmaz → yalnız denemelerde 1 katılım.
  @@unique([userId, examId])
  @@index([userId])
  @@index([examId, status])
  @@map("quiz_sessions")
}

/// Kullanıcı soru hata bildirimi (eski sistemdeki question_reports'un sağlıklı hali).
/// Panelde kuyruğa düşer; içerik kalite döngüsünün kullanıcı ayağı.
model QuestionReport {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String       @map("question_id") @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  message    String
  status     ReportStatus @default(open)
  resolvedBy String?      @map("resolved_by") @db.Uuid
  createdAt  DateTime     @default(now()) @map("created_at")
  resolvedAt DateTime?    @map("resolved_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([questionId])
  @@map("question_reports")
}

enum ReportStatus {
  open
  resolved
  dismissed
}

model QuizAnswer {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String   @map("session_id") @db.Uuid
  questionId        String   @map("question_id") @db.Uuid
  questionVersionId String   @map("question_version_id") @db.Uuid // çözülen tam sürüm sabitlenir (Doc 6 §5)
  selectedOptionId  String?  @map("selected_option_id") @db.Uuid // boş = null
  isCorrect         Boolean? @map("is_correct")
  answeredAt        DateTime @default(now()) @map("answered_at")
  timeSpentMs       Int?     @map("time_spent_ms")

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("quiz_answers")
}

// ─────────────────────────────────────────────
// Progress & Review (Doc 6 §4.4)
// ─────────────────────────────────────────────

model UserTopicProgress {
  userId         String   @map("user_id") @db.Uuid
  topicId        String   @map("topic_id") @db.Uuid
  solvedCount    Int      @default(0) @map("solved_count")
  correctCount   Int      @default(0) @map("correct_count")
  mastery        Decimal  @default(0) @db.Decimal(4, 3) // 0-1, zayıf konu tespiti
  lastActivityAt DateTime @default(now()) @map("last_activity_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id])

  @@id([userId, topicId])
  @@map("user_topic_progress")
}

model UserStats {
  userId        String   @id @map("user_id") @db.Uuid
  totalSolved   Int      @default(0) @map("total_solved")
  totalCorrect  Int      @default(0) @map("total_correct")
  totalSessions Int      @default(0) @map("total_sessions")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Streak {
  userId         String    @id @map("user_id") @db.Uuid
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  lastActiveDate DateTime? @map("last_active_date") @db.Date
  // Seri sigortası (Doc 24 §7.2, Doc 26 §5): kaçan TEK gün affedilir.
  // Haftalık hak: free 1, premium 3. Hafta = Pzt başlangıçlı UTC (snapshot konv.).
  freezeWeekStart DateTime? @map("freeze_week_start") @db.Date
  freezesUsed     Int       @default(0) @map("freezes_used")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Bookmark {
  userId     String   @map("user_id") @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, questionId])
  @@map("bookmarks")
}

model WrongAnswer {
  userId      String    @map("user_id") @db.Uuid
  questionId  String    @map("question_id") @db.Uuid
  lastWrongAt DateTime  @default(now()) @map("last_wrong_at")
  wrongCount  Int       @default(1) @map("wrong_count")
  resolvedAt  DateTime? @map("resolved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, questionId])
  @@map("wrong_answers")
}

/// AI açıklama önbelleği (Doc 24 §4 Faz 2): aynı soru+şık için BİR KEZ üretilir,
/// herkese servis edilir — maliyet soru başına tek seferdir. İçerik sürüme
/// bağlıdır (soru düzenlenirse yeni sürüm = yeni önbellek satırı).
model AiExplanation {
  questionVersionId String   @map("question_version_id") @db.Uuid
  /// Kullanıcının seçtiği şık — çeldirici analizi şıkka özeldir.
  chosenOptionId    String   @map("chosen_option_id") @db.Uuid
  text              String
  model             String
  createdAt         DateTime @default(now()) @map("created_at")

  @@id([questionVersionId, chosenOptionId])
  @@map("ai_explanations")
}

/// Uygulama ayarları (anahtar-değer) — admin panelden yönetilir.
/// Örn. show_question_source: kaynak etiketi kullanıcıya gösterilsin mi.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ─────────────────────────────────────────────
// Gamification + Kişisel Koç (Doc 19)
// ─────────────────────────────────────────────

/// Rozet kataloğu — seed ile yüklenir; kazanım kuralı kind+threshold ile
/// deterministiktir (örn. streak/7 = "7 Gün Seri").
model Badge {
  key         String    @id // streak_7, solved_100, first_exam…
  name        String
  description String
  kind        BadgeKind
  threshold   Int // eşik: gün / soru / deneme sayısı / % doğruluk
  sortOrder   Int       @default(0) @map("sort_order")

  earners UserBadge[]

  @@map("badges")
}

enum BadgeKind {
  streak // currentStreak >= threshold
  solved // totalSolved >= threshold
  exam // tamamlanan deneme sayısı >= threshold
  accuracy // doğruluk %'si >= threshold (min 100 soru sonrası)
}

model UserBadge {
  userId   String   @map("user_id") @db.Uuid
  badgeKey String   @map("badge_key")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeKey], references: [key])

  @@id([userId, badgeKey])
  @@map("user_badges")
}

/// Haftalık konu ustalığı fotoğrafı — trend kartları ("bu hafta %12 arttı")
/// ve ileride AI koç analizleri için (Doc 19 §2.1). weekStart = Pazartesi.
model TopicMasterySnapshot {
  userId    String   @map("user_id") @db.Uuid
  topicId   String   @map("topic_id") @db.Uuid
  weekStart DateTime @map("week_start") @db.Date
  mastery   Decimal  @db.Decimal(4, 3)
  solved    Int      @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id])

  @@id([userId, topicId, weekStart])
  @@index([userId, weekStart])
  @@map("topic_mastery_snapshots")
}

// ─────────────────────────────────────────────
// Migration (kullanıcı göçü — paem705 kaynak)
// ─────────────────────────────────────────────

model LegacyUserMap {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  newUserId             String       @map("new_user_id") @db.Uuid
  legacySource          LegacySource @map("legacy_source")
  legacyId              String       @map("legacy_id")
  legacyEmail           String       @map("legacy_email")
  migratedAt            DateTime     @default(now()) @map("migrated_at")
  passwordResetRequired Boolean      @default(true) @map("password_reset_required")

  @@index([newUserId])
  @@index([legacyEmail])
  @@map("legacy_user_map")
}
